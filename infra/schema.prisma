generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  username      String   @unique
  passwordHash  String
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  conversations Conversation[]
}

model Conversation {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @db.Uuid
  title               String
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @db.Timestamptz(6)
  messages            Json     @default("[]")
  systemPrompt        String
  storyState          String
  previousStoryState  String?
  storyStateLastUpdated DateTime? @db.Timestamptz(6)
  settings            Json
  systemPromptBaseline String?
  storyStateBaseline  String?
  lastIncludedAt      Json     @default("{}")
  customSegments      Json?
  structuredState     Json?
  lastSummarizedTurn  Int      @default(0)
  lastPipelineTurn    Int      @default(0)
  stateHistoryEntries StateHistoryEntry[]
  user                User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model StateHistoryEntry {
  id             String   @id @db.Uuid
  conversationId String   @db.Uuid
  timestamp      DateTime @db.Timestamptz(6)
  turnStart      Int
  turnEnd        Int
  previousState  String
  newState       String
  extractedFacts Json
  validation     Json
  disposition    String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
}

// MessageEmbedding table is managed via raw SQL migration (pgvector).
// Not modeled here because Prisma does not support the `vector` column type.
// See migration 202602260001_message_embeddings for the schema.
