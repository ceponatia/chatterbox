generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  username      String   @unique
  passwordHash  String
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  conversations Conversation[]
  storyProjects StoryProject[]
}

model Conversation {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @db.Uuid
  storyProjectId        String?  @db.Uuid
  title                 String
  createdAt             DateTime @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @db.Timestamptz(6)
  messages              Json     @default("[]")
  systemPrompt          String
  storyState            String
  previousStoryState    String?
  storyStateLastUpdated DateTime? @db.Timestamptz(6)
  settings              Json
  systemPromptBaseline String?
  storyStateBaseline    String?
  lastIncludedAt        Json     @default("{}")
  customSegments        Json?
  structuredState       Json?
  lastPipelineTurn      Int      @default(0)
  lastStateUpdateAt              DateTime?  @db.Timestamptz(6)
  lastStateCheckpointMessageId   String?
  stateRefreshLeaseExpiresAt     DateTime?  @db.Timestamptz(6)
  candidateFacts                 Json?
  lastSlowLaneAt                 DateTime?  @db.Timestamptz(6)
  stateHistoryEntries StateHistoryEntry[]
  storyProject         StoryProject? @relation(fields: [storyProjectId], references: [id])
  user                 User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([storyProjectId])
}

model StoryProject {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @db.Uuid
  name                   String
  description            String   @default("")
  authoringMode          String   @default("form")
  importedSystemPrompt   String?
  importedStoryState     String?
  generatedSystemPrompt  String   @default("")
  generatedStoryState    String   @default("")
  generatedSegments      Json?
  generatedStructuredState Json?
  segmentOverrides       Json?
  mainEntityId           String?
  promptBlueprint        Json?
  runtimeSeed            Json?
  createdAt              DateTime @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @db.Timestamptz(6)
  characters             StoryCharacter[]
  conversations          Conversation[]
  relationships          StoryRelationship[]
  user                   User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model StoryCharacter {
  id               String   @id @default(uuid()) @db.Uuid
  storyProjectId   String   @db.Uuid
  entityId         String
  name             String
  role             String   @default("supporting")
  isPlayer         Boolean  @default(false)
  identity         Json?
  background       String?
  appearance       Json?
  behavioralProfile Json?
  dialogueExamples  Json?
  startingDemeanor String?
  provenance       Json?
  importedMarkdown String?
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @db.Timestamptz(6)
  storyProject     StoryProject @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)

  @@index([storyProjectId])
  @@unique([storyProjectId, entityId])
}

// The single-player-character partial unique index is managed via raw SQL migration
// because Prisma does not support filtered unique indexes in schema syntax.

model StoryRelationship {
  id             String   @id @default(uuid()) @db.Uuid
  storyProjectId String   @db.Uuid
  fromEntityId   String
  toEntityId     String
  description    String
  details        Json     @default("[]")
  tone           String?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)
  storyProject   StoryProject @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)

  @@index([storyProjectId])
}

model StateHistoryEntry {
  id             String   @id @db.Uuid
  conversationId String   @db.Uuid
  timestamp      DateTime @db.Timestamptz(6)
  turnStart      Int
  turnEnd        Int
  previousState  String
  newState       String
  extractedFacts Json
  validation     Json
  disposition    String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
}

// MessageEmbedding table is managed via raw SQL migration (pgvector).
// Not modeled here because Prisma does not support the `vector` column type.
// See migration 202602260001_message_embeddings for the schema.
