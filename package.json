{
  "name": "chatterbox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "fetch:providers": "node --experimental-strip-types scripts/fetch-providers.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@prisma/client": "^7.4.0",
    "eslint": "^9",
    "eslint-plugin-boundaries": "^5",
    "prisma": "^7.0.0",
    "typescript": "^5"
  }
}
